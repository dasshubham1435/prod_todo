{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A task object that users can manage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "completed": { "type": "boolean" },
        "reminderAt": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "priority", "completed", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "tasks": {
      "schema": "Task",
      "description": "User tasks collection"
    }
  }
}
