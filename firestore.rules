rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    match /tasks/{taskId} {
      function isValidTask(data) {
        return data.userId == request.auth.uid &&
               data.title is string && data.title.size() > 0 && data.title.size() <= 500 &&
               data.priority in ['low', 'medium', 'high'] &&
               data.completed is bool &&
               (data.description == null || data.description is string) &&
               (data.reminderAt == null || data.reminderAt is timestamp) &&
               (data.dueDate == null || data.dueDate is timestamp) &&
               data.createdAt is timestamp &&
               data.updatedAt is timestamp;
      }

      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidTask(incoming()) && 
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
      
      allow update: if isSignedIn() && 
                      isOwner(existing().userId) &&
                      isValidTask(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time;
      
      allow delete: if isOwner(existing().userId);
    }
  }
}
